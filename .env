# Local development database (SQLite). Swap provider + URL to migrate to
# PostgreSQL (Supabase / Neon) later.
DATABASE_URL="file:./dev.db"

# Meta (Facebook) tracking. Leave empty to disable the integration entirely.
# NEXT_PUBLIC_META_PIXEL_ID: the Pixel / dataset id from Meta Events Manager.
# META_CONVERSIONS_API_ACCESS_TOKEN: server-side Conversions API token
#   (Events Manager > Settings > Conversions API > Generate access token).
# META_TEST_EVENT_CODE: optional, routes CAPI events to the Test Events tab.
NEXT_PUBLIC_META_PIXEL_ID=
META_CONVERSIONS_API_ACCESS_TOKEN=
META_TEST_EVENT_CODE=
