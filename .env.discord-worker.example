# Discord DM worker — environment variables (example)
#
# Copy these into your Cybrancee app's environment settings (or a local .env at
# the repo root for local runs). Do NOT commit real values.
#
# The worker needs ONLY these three variables. It never touches the database and
# never needs DATABASE_URL.

# Discord bot token (Developer Portal → your app → Bot → Reset Token).
# Server-only secret. Must never be exposed client-side.
DISCORD_BOT_TOKEN=replace_with_discord_bot_token

# Shared HMAC secret used to authenticate the worker to the web app's
# /api/discord/activate endpoint. Must EXACTLY match the DISCORD_DM_WORKER_SECRET
# configured in Vercel (the web app), or activation fails with 401/503.
DISCORD_DM_WORKER_SECRET=replace_with_same_secret_as_vercel

# Base URL of the deployed web app (no trailing slash). The worker calls
# ${INTERNAL_API_BASE_URL}/api/discord/activate.
INTERNAL_API_BASE_URL=https://ghost.ma
