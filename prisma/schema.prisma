// Prisma schema for the Karta digital store.
//
// SQLite is used for local development so the project has a real database
// structure that can later be migrated to PostgreSQL (Supabase / Neon) by
// swapping the datasource `provider` and `DATABASE_URL`.
//
// NOTE: SQLite has no native enum type, so status fields are stored as
// strings. The allowed values are documented next to each field and mirrored
// by the TypeScript unions in src/lib/types.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  category     String
  priceMad     Int
  region       String
  deliveryType String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  digitalCodes   DigitalCode[]
  orderItems     OrderItem[]
  deliveredCodes DeliveredCode[]
}

model DigitalCode {
  id              String    @id @default(cuid())
  productId       String
  code            String
  // status: "unused" | "reserved" | "used" | "disabled"
  status          String    @default("unused")
  assignedOrderId String?
  reservedAt      DateTime?
  usedAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  product        Product         @relation(fields: [productId], references: [id])
  deliveredCodes DeliveredCode[]

  @@unique([productId, code])
  @@index([productId, status])
}

model Order {
  id            String   @id @default(cuid())
  customerName  String
  customerEmail String
  // status: "pending_payment" | "payment_submitted" | "payment_confirmed"
  //       | "payment_issue" | "rejected" | "delivered" | "refunded" | "cancelled"
  status        String   @default("pending_payment")
  paymentMethod String
  totalMad      Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items          OrderItem[]
  deliveredCodes DeliveredCode[]
  emailLogs      EmailLog[]
  paymentProof   PaymentProof?
  paymentEvents  PaymentEvent[]
}

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  productId    String
  quantity     Int
  unitPriceMad Int

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id])
  deliveredCodes DeliveredCode[]
}

model DeliveredCode {
  id            String   @id @default(cuid())
  orderId       String
  orderItemId   String
  productId     String
  digitalCodeId String?
  manualCode    String?
  deliveredAt   DateTime @default(now())

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])
  digitalCode DigitalCode? @relation(fields: [digitalCodeId], references: [id])

  @@index([orderId])
}

model EmailLog {
  id        String   @id @default(cuid())
  orderId   String
  // type: "order_received" | "payment_submitted" | "payment_confirmed"
  //      | "payment_rejected" | "payment_issue" | "code_delivered"
  type      String
  recipient String
  subject   String
  body      String
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Customer-uploaded payment proof (PNG / JPG / JPEG / PDF).
// Stored as base64 string for prototype; swap to object storage (S3/R2) in production.
model PaymentProof {
  id         String   @id @default(cuid())
  orderId    String   @unique
  fileName   String
  mimeType   String
  data       String   // base64-encoded file content
  uploadedAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// Audit trail for payment lifecycle events.
model PaymentEvent {
  id         String   @id @default(cuid())
  orderId    String
  type       String   // "status_change" | "proof_uploaded" | "admin_note"
  fromStatus String?
  toStatus   String?
  note       String?
  createdAt  DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Bank account for bank-transfer payment method.
model Bank {
  id            String   @id @default(cuid())
  name          String
  accountHolder String
  accountNumber String   @default("")
  rib           String   @default("")
  iban          String   @default("")
  swift         String   @default("")
  instructions  String   @default("")
  enabled       Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// USDT wallet configuration (TRC20 / BEP20).
model CryptoWallet {
  id           String   @id @default(cuid())
  coin         String   @default("USDT")
  network      String   // "TRC20" | "BEP20"
  address      String
  label        String   @default("")
  instructions String   @default("")
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Per-method configuration (enabled, proof required, method-specific fields).
model PaymentMethodConfig {
  id            String   @id @default(cuid())
  method        String   @unique // "bank" | "usdt" | "paypal" | "card"
  enabled       Boolean  @default(true)
  proofRequired Boolean  @default(true)
  paypalEmail   String   @default("")
  cardMessage   String   @default("Paiement par carte bientôt disponible.")
  instructions  String   @default("")
  updatedAt     DateTime @default(now()) @updatedAt
}

// Global support contact info.
model SupportConfig {
  id             String   @id @default(cuid())
  whatsappNumber String   @default("+212 600 000 000")
  supportEmail   String   @default("support@karta.ma")
  instructions   String   @default("")
  updatedAt      DateTime @default(now()) @updatedAt
}
