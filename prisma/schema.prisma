// Prisma schema for the ghost.ma digital store.
//
// Supabase/PostgreSQL is the production source of truth. Status fields remain
// strings so the TypeScript unions in src/lib/types.ts define the allowed set.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  category         String
  description      String   @default("")
  shortDescription String?
  longDescription  String?
  instructions     String?
  brand            String?
  priceMad         Int
  region           String
  deliveryType     String
  imageUrl         String?
  featured         Boolean  @default(true)
  active           Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  categoryRecord Category? @relation(fields: [category], references: [id])
  digitalCodes   DigitalCode[]
  orderItems     OrderItem[]
  deliveredCodes DeliveredCode[]
  media          ProductMedia[]
  variants       ProductVariant[]

  @@index([active, sortOrder])
  @@index([category, active])
}

model Category {
  id            String   @id
  slug          String   @unique
  name          String
  description   String   @default("")
  tagline       String   @default("")
  gradient      String   @default("from-[#1b2838] to-[#2a475e]")
  icon          String   @default("")
  iconUrl       String?
  coverImageUrl String?
  accentColor   String   @default("#3e7bfa")
  active        Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  products Product[]
}

model ProductMedia {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String   @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id               String   @id @default(cuid())
  productId        String
  name             String
  priceMad         Int
  faceValue        Float?
  faceCurrency     String   @default("MAD")
  // stockControl: "manual" | "api" | "reloadly"
  stockControl     String   @default("manual")
  stockMode        String   @default("automatic")
  supplierCost     Float?
  supplierCurrency String   @default("MAD")
  // Only used when stockControl = "reloadly"
  reloadlyProductId   Int?
  reloadlyCountryCode String?
  // When true, deliverOrder()'s automatic pre-pass (fired on payment
  // confirmation) will attempt to purchase this variant from Reloadly
  // without any admin action. When false, the variant stays mapped to
  // Reloadly (for the admin's manual "Via Reloadly" delivery toggle) but
  // is never purchased automatically.
  reloadlyAutomationEnabled Boolean @default(false)
  active           Boolean  @default(true)
  featured         Boolean  @default(false)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  digitalCodes DigitalCode[]
  orderItems   OrderItem[]

  @@index([productId])
  @@index([productId, active])
}

model DigitalCode {
  id              String    @id @default(cuid())
  productId       String
  variantId       String?
  code            String
  // status: "unused" | "reserved" | "used" | "disabled"
  status          String    @default("unused")
  assignedOrderId String?
  reservedAt      DateTime?
  usedAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  product        Product         @relation(fields: [productId], references: [id])
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  deliveredCodes DeliveredCode[]

  @@unique([productId, code])
  @@index([productId, status])
  @@index([variantId, status])
}

model Order {
  id            String   @id @default(cuid())
  customerId    String?
  customerName  String
  customerEmail String
  // status: "pending_payment" | "payment_submitted" | "payment_confirmed"
  //       | "payment_issue" | "rejected" | "delivered" | "refunded" | "cancelled"
  status        String   @default("pending_payment")
  paymentMethod String
  totalMad      Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt
  // Live DB column, auto-populated on every insert. Not read by application
  // code — public order numbers are computed on the fly from creation-order
  // sequence (see src/lib/orderNumber.ts) rather than this column. Kept here
  // only so the schema matches reality; not wired into any query.
  orderNumber   Int      @unique @default(autoincrement())

  // Automated payment provider reconciliation (e.g. PayPal). Null for manual
  // methods (bank transfer, crypto, cash). Amount/currency are the values
  // locked in when the provider order was created, so capture/webhook
  // verification always compares against a fixed snapshot rather than a
  // conversion rate that may have since changed.
  paymentProvider           String?
  paymentProviderOrderId    String?   @unique
  paymentProviderCaptureId  String?   @unique
  paymentProviderStatus     String?
  paymentProviderRawStatus  String?
  paymentProviderAmount     Float?
  paymentProviderCurrency   String?
  paymentConfirmedAt        DateTime?

  items          OrderItem[]
  deliveredCodes DeliveredCode[]
  emailLogs      EmailLog[]
  paymentProof   PaymentProof?
  paymentEvents  PaymentEvent[]
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([customerEmail])
  @@index([createdAt])
  @@index([paymentMethod])
  @@index([paymentMethod, createdAt])
  @@index([customerId])
  @@index([paymentProviderOrderId])
}

model Customer {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  role                 String    @default("CUSTOMER")
  phone                String?
  image                String?
  googleId             String?   @unique
  authProvider         String?
  passwordHash         String?
  emailVerified        Boolean   @default(false)
  emailVerifiedAt      DateTime?
  lastLoginAt          DateTime?
  lastPasswordChangeAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @default(now()) @updatedAt
  firstName            String?
  lastName             String?

  orders Order[]
  emailLogs EmailLog[]
  authTokens AuthToken[]

  @@index([updatedAt])
  @@index([emailVerified])
  @@index([role])
}

model AuthToken {
  id         String    @id @default(cuid())
  customerId String
  // type: "email_verification" | "password_reset"
  type       String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, type])
  @@index([expiresAt])
}

model OrderItem {
  id           String @id @default(cuid())
  orderId      String
  productId    String
  variantId    String?
  quantity     Int
  unitPriceMad Int

  // Automatic-supplier fulfillment tracking (Reloadly today). Independent of
  // Order.status, which stays the single customer-facing lifecycle field —
  // these columns exist so a partially-automated order (some items fulfilled
  // by Reloadly, others still needing a manual code) can be represented and
  // retried without losing state.
  // fulfillmentStatus: "pending" | "fulfilled" | "failed"
  fulfillmentStatus        String    @default("pending")
  // fulfillmentSource: "reloadly" | "manual" | null (not yet attempted)
  fulfillmentSource         String?
  fulfillmentError          String?
  reloadlyTransactionId     Int?
  reloadlyOrderId           Int?
  fulfillmentAttempts       Int       @default(0)
  lastFulfillmentAttemptAt  DateTime?

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id])
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  deliveredCodes DeliveredCode[]

  @@index([variantId])
  @@index([fulfillmentStatus])
}

model DeliveredCode {
  id            String   @id @default(cuid())
  orderId       String
  orderItemId   String
  productId     String
  digitalCodeId String?
  manualCode    String?
  // source: "local" | "reloadly" — audit metadata only, code text lives in
  // digitalCode.code (local) or manualCode (manual entry + reloadly)
  source                String   @default("local")
  reloadlyTransactionId Int?
  reloadlyOrderId       Int?
  deliveredAt   DateTime @default(now())

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])
  digitalCode DigitalCode? @relation(fields: [digitalCodeId], references: [id])

  @@index([orderId])
  @@unique([digitalCodeId])
}

model EmailLog {
  id        String   @id @default(cuid())
  orderId   String?
  customerId String?
  // type: "order_received" | "payment_submitted" | "payment_confirmed"
  //      | "payment_rejected" | "payment_issue" | "code_delivered"
  type      String
  templateKey String?
  recipient String
  subject   String
  body      String
  html      String   @default("")
  text      String   @default("")
  provider  String   @default("simulation")
  providerMessageId String?
  status    String   @default("simulated")
  errorMessage String?
  manuallyEdited Boolean @default(false)
  metadata Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([templateKey])
}

// Customer-uploaded payment proof (PNG / JPG / JPEG / PDF).
// Stored as base64 in PostgreSQL until object storage is configured.
model PaymentProof {
  id         String   @id @default(cuid())
  orderId    String   @unique
  fileName   String
  mimeType   String
  data       String   // base64-encoded file content
  uploadedAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([uploadedAt])
}

// Audit trail for payment lifecycle events.
model PaymentEvent {
  id         String   @id @default(cuid())
  orderId    String
  type       String   // "status_change" | "proof_uploaded" | "admin_note"
  fromStatus String?
  toStatus   String?
  note       String?
  createdAt  DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

// Dedupe/idempotency ledger for verified payment-provider webhooks (PayPal,
// etc). Only stores identifiers needed to reconcile — never the raw payload,
// which may carry payer/payment details.
model PaymentWebhookEvent {
  id          String   @id @default(cuid())
  provider    String // "paypal"
  eventId     String   @unique
  eventType   String
  resourceId  String?
  orderId     String?
  processedAt DateTime @default(now())

  @@index([provider])
  @@index([orderId])
}

// Generic, reorderable payment method shown at checkout. One row per
// customer-facing method (a bank account, a crypto wallet, PayPal, card,
// cash, or a fully custom method) — replaces the old fixed
// Bank/CryptoWallet/PaymentMethodConfig tables so admins can add/remove/
// reorder/archive any number of methods of any type.
model PaymentMethod {
  id            String    @id @default(cuid())
  type          String // "bank" | "paypal" | "crypto" | "card" | "cash" | "custom"
  name          String // customer-facing name
  subtitle      String    @default("")
  customerNote  String    @default("")
  status        String    @default("active") // "active" | "inactive"
  visible       Boolean   @default(true)
  sortOrder     Int       @default(0)
  logoUrl       String?
  initials      String    @default("")
  accentColor   String    @default("#3e7bfa")
  logoType      String    @default("initials") // "initials" | "image" | "icon"
  details       Json      @default("{}") // per-type fields (rib, walletAddress, paypalEmail, ...)
  proofRequired Boolean   @default(true)
  internalNote  String    @default("")
  minAmount     Float?
  maxAmount     Float?
  regions       String[]  @default([])
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([sortOrder])
}

// Global support contact info.
model SupportConfig {
  id             String   @id @default(cuid())
  whatsappNumber String   @default("+212 600 000 000")
  supportEmail   String   @default("support@ghost.ma")
  instructions   String   @default("")
  updatedAt      DateTime @default(now()) @updatedAt
}

model StoreSetting {
  id        String   @id
  value     Json
  updatedAt DateTime @default(now()) @updatedAt
}
