// Prisma schema for the ghost.ma digital store.
//
// Supabase/PostgreSQL is the production source of truth. Status fields remain
// strings so the TypeScript unions in src/lib/types.ts define the allowed set.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  category          String
  description       String   @default("")
  shortDescription  String?
  longDescription   String?
  instructions      String?
  brand             String?
  priceMad          Int
  region            String
  deliveryType      String
  imageUrl          String?
  featured          Boolean  @default(true)
  active            Boolean  @default(true)
  sortOrder         Int      @default(0)
  // Centralized, admin-maintained public-search aliases (accent/case-insensitive
  // match only, e.g. "psn", "carte steam"). Never rendered as visible product
  // data. Kept alongside the global alias table in src/lib/search/text.ts.
  searchAliases     String[] @default([])
  // Pricing-policy override for the suggested-price engine only (see
  // docs/pricing-architecture.md). Percentage, e.g. 8.5 = 8.5%. NEVER touches
  // the published priceMad — it only feeds the margin-resolution ladder.
  marginPctOverride Decimal? @db.Decimal(6, 3)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  categoryRecord  Category?               @relation(fields: [category], references: [id])
  digitalCodes    DigitalCode[]
  orderItems      OrderItem[]
  deliveredCodes  DeliveredCode[]
  media           ProductMedia[]
  variants        ProductVariant[]
  collectionItems CollectionProduct[]
  promoCodeLinks  PromoCodeProduct[]
  wishlistItems   WishlistItem[]
  recentlyViewed  RecentlyViewedProduct[]

  @@index([active, sortOrder])
  @@index([category, active])
}

// Curated storefront merchandising group (e.g. "Tendances", "Meilleures ventes",
// "Cartes cadeaux"). Distinct from Category: a Category describes WHAT a product
// is (a required FK on Product), while a Collection is an admin-curated group
// that can change over time and a product may belong to many. Membership is
// parent-product level (see CollectionProduct) so one product family is not
// repeated once per denomination. Collections carry their own storefront
// visibility window, homepage placement, SEO, and search aliases. All display
// data (price, media, region, stock) is always read live from the referenced
// Product — never duplicated here.
model Collection {
  id               String    @id @default(cuid())
  slug             String    @unique
  name             String
  shortDescription String    @default("")
  longDescription  String    @default("")
  // Optional compact banner/hero artwork (URL or data: URI, like ProductMedia).
  imageUrl         String?
  // Publication state. Defaults to false so an imported/created collection is
  // never auto-published — an admin must explicitly activate it.
  active           Boolean   @default(false)
  sortOrder        Int       @default(0)
  // Optional schedule window. Visibility is computed at render/query time from
  // active + startAt/endAt vs. now (no cron needed). Before startAt: hidden;
  // after endAt: expired/hidden. Null bounds mean "no lower/upper limit".
  startAt          DateTime?
  endAt            DateTime?
  // Homepage placement.
  showOnHomepage   Boolean   @default(false)
  // Optional homepage section-title override (falls back to `name`).
  homepageTitle    String    @default("")
  homepageLimit    Int       @default(8)
  // Optional "Voir tout" CTA label override on the homepage section.
  ctaLabel         String    @default("")
  // SEO for the public /collections/<slug> page (fall back to name/description).
  seoTitle         String    @default("")
  seoDescription   String    @default("")
  socialImageUrl   String?
  // Centralized, admin-maintained search aliases matched by the public search
  // (accent/case-insensitive). Never rendered as visible product data.
  aliases          String[]  @default([])
  // Homepage/compact-card visual identity. `icon` is an approved icon KEY (see
  // src/lib/collections/icons.ts) — never raw SVG/HTML; empty means "derive from
  // name or fall back". `accentColor` is an optional restrained accent hex for
  // the card's glow/hover; null falls back to the Ghost blue.
  icon             String    @default("")
  accentColor      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt

  items CollectionProduct[]

  @@index([active, sortOrder])
}

// Ordered parent-product membership for a Collection. A safe join model: it
// stores only the reference + display order, never a price/media snapshot, so
// the storefront always reads current product data. Unique (collectionId,
// productId) prevents duplicate membership.
model CollectionProduct {
  id           String   @id @default(cuid())
  collectionId String
  productId    String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([collectionId, productId])
  @@index([collectionId])
  @@index([productId])
}

model Category {
  id                String   @id
  slug              String   @unique
  // Keyword-rich localized URL slug for the public category landing page
  // (/categorie/<seoSlug>, e.g. "carte-steam-au-maroc"). Distinct from `slug`
  // (the id-ish key). Nullable: categories without one fall back to the
  // ?category= filter URL. See src/lib/categoryUrl.ts.
  seoSlug           String?  @unique
  name              String
  description       String   @default("")
  tagline           String   @default("")
  gradient          String   @default("from-[#1b2838] to-[#2a475e]")
  icon              String   @default("")
  iconUrl           String?
  coverImageUrl     String?
  accentColor       String   @default("#3e7bfa")
  active            Boolean  @default(true)
  sortOrder         Int      @default(0)
  // Optional category-level margin override for the suggested-price engine
  // only. Percentage. Does not affect any published price directly.
  marginPctOverride Decimal? @db.Decimal(6, 3)
  // Optional rich category landing-page content (hero, intro, info points,
  // Navigator tip, FAQ, related categories, SEO). Stored as a single JSON blob
  // — see src/lib/categoryLanding.ts for the shape and normalizer. Null / absent
  // means the category renders as a plain product grid (no landing sections).
  landing           Json?
  // Centralized, admin-maintained public-search aliases (accent/case-insensitive
  // match only). Mirrors Collection.aliases. Never rendered as visible data.
  aliases           String[] @default([])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  products       Product[]
  promoCodeLinks PromoCodeCategory[]
  guides         Guide[]
}

// Customer-education content page (e.g. "Comment activer une carte Steam").
// Real SEO-friendly public routes at /guides/<slug>, not modal-only content.
// The structured body (typed content blocks), FAQ, and Navigator tip are stored
// as normalized JSON blobs — mirroring the Category.landing pattern — so we avoid
// a fan of tiny join tables while keeping the shape validated on read/write in
// src/lib/guide.ts. Related products/guides are id arrays resolved live (and
// filtered to visible records) at render time, never snapshots.
model Guide {
  id                String    @id @default(cuid())
  slug              String    @unique
  title             String
  summary           String    @default("")
  // Free-form platform/category badge label shown on the guide (e.g.
  // "PlayStation", "Steam"). Distinct from the optional structured Category link.
  platform          String    @default("")
  // Optional link to a real Category for cross-linking / filtering the index.
  categoryId        String?
  heroImageUrl      String?
  // Approved icon KEY (see src/lib/guide.ts) — never raw SVG/HTML.
  icon              String    @default("")
  // Array of typed content blocks (heading/paragraph/steps/list/image/warning/
  // navigatorTip/payment/productRecommendation/faq/cta). Sanitized on write.
  content           Json?
  // Visible FAQ items [{ id, question, answer }] — the ONLY source of FAQ schema.
  faq               Json?
  // Navigator tip { enabled, title, message, type, ctaLabel, ctaUrl }.
  navigatorTip      Json?
  // Related content resolved live; hidden/inactive targets are dropped at render.
  relatedProductIds String[]  @default([])
  relatedGuideIds   String[]  @default([])
  // Public-search aliases/keywords (accent/case-insensitive). Never rendered.
  aliases           String[]  @default([])
  // Publication. `published` gates public visibility & sitemap inclusion.
  // `scheduledAt` in the future keeps it out of public reads until then.
  published         Boolean   @default(false)
  featured          Boolean   @default(false)
  sortOrder         Int       @default(0)
  publishedAt       DateTime?
  scheduledAt       DateTime?
  archivedAt        DateTime?
  // SEO
  seoTitle          String    @default("")
  seoDescription    String    @default("")
  socialImageUrl    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  category Category? @relation(fields: [categoryId], references: [id])

  @@index([published, sortOrder])
  @@index([published, featured])
  @@index([categoryId])
}

// Persistent per-customer wishlist ("Favoris"). One row per customer + parent
// product (enforced by the unique constraint — the storefront never stores a
// variant here). Cascade-deleted with the customer or product. Designed so
// restock/price notifications can be layered on later without a migration; no
// notification state is implied to exist yet.
model WishlistItem {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([customerId])
  @@index([productId])
}

// Optional server-side "Consultés récemment" history for logged-in customers.
// The launch behavior keeps recently-viewed in localStorage (guests AND
// logged-in); this table exists so account-level cross-device sync can be turned
// on later without a schema change. One row per customer + parent product;
// re-viewing bumps viewedAt. Not yet written by the app.
model RecentlyViewedProduct {
  id         String   @id @default(cuid())
  customerId String
  productId  String
  viewedAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
  @@index([customerId, viewedAt])
}

model ProductMedia {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String   @default("")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductVariant {
  id                          String   @id @default(cuid())
  productId                   String
  name                        String
  priceMad                    Int
  faceValue                   Float?
  faceCurrency                String   @default("MAD")
  // Optional per-variant region (a Ghost region code, e.g. "EU"/"US"). Null →
  // inherits the parent Product.region. Lets one parent product hold variants
  // for multiple regions; the storefront shows a "Région" selector only when a
  // product has more than one distinct variant region.
  region                      String?
  // stockControl: "manual" | "api" | "reloadly"
  stockControl                String   @default("manual")
  stockMode                   String   @default("automatic")
  supplierCost                Float?
  supplierCurrency            String   @default("MAD")
  // Only used when stockControl = "reloadly"
  reloadlyProductId           Int?
  reloadlyCountryCode         String?
  // ── Pricing-policy overrides (suggested-price engine ONLY) ──────────────
  // These never mutate priceMad. They shape what the engine *suggests*; a
  // human still explicitly publishes. See docs/pricing-architecture.md.
  //   marginPctOverride       — variant margin %, wins over product/category/global.
  //   fixedSuggestedPriceMad  — pin the suggested price to this exact MAD amount,
  //                             bypassing cost/FX/margin/rounding. Still requires
  //                             an explicit "Publier" to become priceMad.
  marginPctOverride           Decimal? @db.Decimal(6, 3)
  fixedSuggestedPriceMad      Int?
  // Admin-only market reference price (informational). NEVER shown to customers,
  // never affects storefront/suggested/published pricing. See docs/pricing-architecture.md.
  competitorReferencePriceMad Int?
  competitorReferenceSource   String?
  active                      Boolean  @default(true)
  featured                    Boolean  @default(false)
  sortOrder                   Int      @default(0)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @default(now()) @updatedAt

  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  digitalCodes DigitalCode[]
  orderItems   OrderItem[]

  @@index([productId])
  @@index([productId, active])
}

model DigitalCode {
  id              String    @id @default(cuid())
  productId       String
  variantId       String?
  code            String
  // status: "unused" | "reserved" | "used" | "disabled"
  status          String    @default("unused")
  assignedOrderId String?
  reservedAt      DateTime?
  usedAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt

  product        Product         @relation(fields: [productId], references: [id])
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  deliveredCodes DeliveredCode[]

  @@unique([productId, code])
  @@index([productId, status])
  @@index([variantId, status])
}

model Order {
  id                    String   @id @default(cuid())
  customerId            String?
  customerName          String
  customerEmail         String
  // status: "pending_payment" | "payment_submitted" | "payment_confirmed"
  //       | "payment_issue" | "rejected" | "delivered" | "refunded" | "cancelled"
  status                String   @default("pending_payment")
  paymentMethod         String
  // The amount the customer actually owes/pays. When a promo with an immediate
  // discount is applied, this is the DISCOUNTED total (subtotal - discountMad),
  // so every payment surface (PayPal/bank/USDT) and revenue query keeps using
  // totalMad unchanged. Ghost Credit rewards never touch this — the customer
  // still pays the full amount. Subtotal is derivable as totalMad + discountMad.
  totalMad              Int
  // Immediate promo discount applied to this order (whole MAD, 0 when none).
  // Additive with a safe default so every historical order stays untouched.
  discountMad           Int      @default(0)
  // Ghost Credit the customer chose to SPEND on this order (whole MAD, 0 when
  // none). Reduces totalMad like the discount does. Debited from the wallet at
  // order creation and re-credited if the order is cancelled/rejected/refunded.
  ghostCreditAppliedMad Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt
  // Live DB column, auto-populated on every insert. Not read by application
  // code — public order numbers are computed on the fly from creation-order
  // sequence (see src/lib/orderNumber.ts) rather than this column. Kept here
  // only so the schema matches reality; not wired into any query.
  orderNumber           Int      @unique @default(autoincrement())

  // Unguessable secret embedded in the "Voir ma livraison" email link. The
  // public order number is a sequential, enumerable value, so it is NOT
  // sufficient to reveal delivered codes; possession of this token (or being
  // the logged-in order owner) is what authorizes code disclosure on the
  // delivery page. Populated on delivery; see src/lib/db/fulfillment.ts.
  deliveryToken String? @unique

  // Automated payment provider reconciliation (e.g. PayPal). Null for manual
  // methods (bank transfer, crypto, cash). Amount/currency are the values
  // locked in when the provider order was created, so capture/webhook
  // verification always compares against a fixed snapshot rather than a
  // conversion rate that may have since changed.
  paymentProvider          String?
  paymentProviderOrderId   String?   @unique
  paymentProviderCaptureId String?   @unique
  paymentProviderStatus    String?
  paymentProviderRawStatus String?
  paymentProviderAmount    Float?
  paymentProviderCurrency  String?
  paymentConfirmedAt       DateTime?

  // #orders is a dashboard, not an event feed: one parent "card" message per
  // order (edited in place as status changes) with a thread attached to it
  // holding the full lifecycle timeline. Both null until the first Discord
  // notification for this order succeeds; either can be re-populated later
  // if recovered after being deleted on the Discord side.
  discordMessageId String?
  discordThreadId  String?

  // Optional per-order Discord DM delivery of the fulfilled code(s). This is an
  // ADDITIVE convenience channel: it never gates whether the order is
  // considered delivered.
  // discordDeliveryStatus: "NOT_REQUESTED" | "PENDING" | "SENT" | "FAILED".
  // `discordDeliveryError` holds a safe category only — never a raw payload/code.
  //
  // `discordDeliveryRequested` is authoritative ONLY once the customer has
  // explicitly toggled the per-order checkbox (`discordDeliveryPreferenceSet`).
  // Until then the order follows the customer's live global preference
  // (`discordOrderDeliveryEnabled`) — so enabling that default later applies to
  // still-pending orders too. Both the payment page and the fulfillment auto-send
  // resolve this effective value; a mere page view never persists it.
  discordDeliveryRequested     Boolean   @default(false)
  // True only after an explicit per-order toggle. False = follow global default.
  discordDeliveryPreferenceSet Boolean   @default(false)
  discordDeliveryStatus        String    @default("NOT_REQUESTED")
  discordDeliveryAttemptedAt   DateTime?
  discordDeliverySentAt        DateTime?
  discordDeliveryError         String?

  items             OrderItem[]
  deliveredCodes    DeliveredCode[]
  emailLogs         EmailLog[]
  paymentProof      PaymentProof?
  paymentEvents     PaymentEvent[]
  customer          Customer?                @relation(fields: [customerId], references: [id], onDelete: SetNull)
  promoRedemption   PromoRedemption?
  promotionSnapshot OrderPromotionSnapshot?
  ghostCreditTxns   GhostCreditTransaction[]
  milestoneGrants   SpendingMilestoneGrant[]

  @@index([status])
  @@index([customerEmail])
  @@index([createdAt])
  @@index([paymentMethod])
  @@index([paymentMethod, createdAt])
  @@index([customerId])
  @@index([paymentProviderOrderId])
}

model Customer {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  role                 String    @default("CUSTOMER")
  phone                String?
  image                String?
  googleId             String?   @unique
  authProvider         String?
  passwordHash         String?
  emailVerified        Boolean   @default(false)
  emailVerifiedAt      DateTime?
  lastLoginAt          DateTime?
  lastPasswordChangeAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @default(now()) @updatedAt
  firstName            String?
  lastName             String?

  // ── Admin-managed account state (Customer Management) ─────────────────────
  // Operational account status set by admins. "active" (default) | "disabled"
  // (blocks login/purchases; data preserved) | "review" (under review) |
  // "fraud_hold". A disabled account is treated as logged-out server-side (see
  // src/lib/auth.ts getCurrentCustomer). Never auto-set by customer flows.
  status             String    @default("active")
  statusReason       String?
  statusUpdatedAt    DateTime?
  // Stateless-session revocation anchor. When set, any session cookie whose
  // issued-at (iat) predates this instant is rejected on the next request — this
  // is how "force logout / revoke sessions" and account-disable invalidate
  // existing HMAC cookies without a DB session table.
  sessionsValidAfter DateTime?
  // Optional customer preferences (admin-editable where operationally needed).
  preferredLanguage  String?
  marketingConsent   Boolean   @default(false)

  // Discord OAuth identity (login/linking source of truth). Separate from the
  // DM fields below: being OAuth-linked does NOT mean the bot can DM this user.
  discordId         String? @unique
  discordUsername   String?
  discordGlobalName String?
  discordAvatar     String?

  // Verified Discord DM state. `discordDmUserId` is set ONLY by the DM worker
  // after the customer sends a valid activation code to the bot — it, not the
  // OAuth id, is the source of truth for DM delivery.
  discordDmUserId             String?
  discordDmUsername           String?
  discordDmDisplayName        String?
  discordDmAvatar             String?
  discordDmActivated          Boolean   @default(false)
  discordDmActivatedAt        DateTime?
  // Customer's global default for whether future eligible orders also go to DM.
  discordOrderDeliveryEnabled Boolean   @default(false)

  // Cached Ghost Credit wallet balance in whole MAD. This is a transactional
  // cache: it is only ever updated inside the same $transaction as the ledger
  // entries in GhostCreditTransaction, and can be re-derived from that ledger at
  // any time (see src/lib/db/ghostCredit.ts deriveBalance). Never the sole source
  // of truth — the ledger is. Additive with a safe default.
  ghostCreditBalanceMad        Int       @default(0)
  // Wallet-wide expiry deadline. Ghost Credit expires after N days of
  // INACTIVITY (default 180, configurable in store settings). Only a QUALIFYING
  // earning event — a promo Ghost Credit reward or a spending-milestone reward
  // granted after a paid+completed order — resets this to earnedAt + N days.
  // Spending, manual admin grants/corrections, refunds, and reversals do NOT
  // reset it (they carry resetsExpiration=false on their ledger row). Null when
  // no cycle exists. Enforced by the wallet-expiry job + lazily on read/spend.
  ghostCreditExpiresAt         DateTime?
  // Timestamp of the last QUALIFYING earning event (the only thing that resets
  // the timer). Distinct from any credit timestamp — manual grants/refunds never
  // touch this. Drives reconciliation of ghostCreditExpiresAt.
  lastQualifyingCreditEarnedAt DateTime?
  // Customer opt-in for the "3 days before expiry" reminder email (default off).
  expirationReminderEnabled    Boolean   @default(false)
  // The ghostCreditExpiresAt value a reminder was last sent for — one reminder
  // per expiration cycle. A new qualifying reward moves the deadline, allowing a
  // fresh reminder. Idempotency anchor for the reminder job.
  expirationReminderSentFor    DateTime?
  // Wallet freeze: blocks SPENDING Ghost Credit (grants/reversals still apply)
  // until an admin resolves it. Set automatically when a refund reversal can't
  // be fully applied because the promotional credit was already spent (so the
  // wallet is never left with an unexplained negative balance), or manually by
  // an admin. Additive with safe defaults.
  walletFrozen                 Boolean   @default(false)
  walletFrozenReason           String?

  orders                 Order[]
  emailLogs              EmailLog[]
  authTokens             AuthToken[]
  discordActivationCodes DiscordActivationCode[]
  ghostCreditTxns        GhostCreditTransaction[]
  promoRedemptions       PromoRedemption[]
  milestoneGrants        SpendingMilestoneGrant[]
  wishlistItems          WishlistItem[]
  recentlyViewed         RecentlyViewedProduct[]
  adminNotes             CustomerNote[]
  adminAuditLogs         AdminAuditLog[]

  @@index([updatedAt])
  @@index([emailVerified])
  @@index([role])
  @@index([status])
  @@index([createdAt])
}

// Append-only admin audit trail for customer-management actions (status change,
// disable/enable, session revoke, verification resend, wallet adjust, note add,
// support reply, data edit, consent change). Never deleted. `customerId` is the
// affected customer (nullable for non-customer-scoped events). `metadata` holds
// safe, non-sensitive changed-field context only — never secrets/tokens/hashes.
model AdminAuditLog {
  id         String   @id @default(cuid())
  adminId    String
  adminName  String
  customerId String?
  action     String
  reason     String?
  metadata   Json?
  createdAt  DateTime @default(now())

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([customerId, createdAt])
  @@index([adminId, createdAt])
  @@index([action])
}

// Private internal admin notes on a customer. Never customer-visible. Append-only
// with soft-delete (archivedAt) — a note is archived, never hard-deleted, so the
// history is preserved (a correction is a new note). Optional category + related
// order for support/fraud/payment context.
model CustomerNote {
  id         String    @id @default(cuid())
  customerId String
  authorId   String
  authorName String
  // "general" | "support" | "fraud" | "payment"
  category   String    @default("general")
  body       String
  orderId    String?
  archivedAt DateTime?
  archivedBy String?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, createdAt])
}

// One-time codes the customer sends to the Ghost.ma bot to prove control of a
// Discord account for DM delivery. Only the hash is stored; codes are
// single-use, short-lived, and superseded codes are invalidated on generation.
// Mirrors AuthToken conventions.
model DiscordActivationCode {
  id         String    @id @default(cuid())
  customerId String
  codeHash   String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt])
}

model AuthToken {
  id         String    @id @default(cuid())
  customerId String
  // type: "email_verification" | "password_reset"
  type       String
  tokenHash  String    @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, type])
  @@index([expiresAt])
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String
  variantId    String?
  quantity     Int
  unitPriceMad Int

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product         @relation(fields: [productId], references: [id])
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  deliveredCodes DeliveredCode[]

  @@index([variantId])
}

model DeliveredCode {
  id                    String   @id @default(cuid())
  orderId               String
  orderItemId           String
  productId             String
  digitalCodeId         String?
  manualCode            String?
  // source: "local" | "reloadly" — audit metadata only, code text lives in
  // digitalCode.code (local) or manualCode (manual entry + reloadly)
  source                String   @default("local")
  reloadlyTransactionId Int?
  reloadlyOrderId       Int?
  // Normalized, provider-specific delivery fields for sources whose payload is
  // richer than a single code (e.g. Reloadly returns cardNumber/pinCode and
  // some products deliver a redemption URL). Shape: an array of
  // { code?, pin?, url?, instructions? } — only the fields that exist for that
  // product are set. Null for plain local/manual single-code deliveries, which
  // continue to use digitalCode.code / manualCode. The customer delivery page
  // renders these as separate labelled fields instead of one opaque string.
  deliveryPayload       Json?
  deliveredAt           DateTime @default(now())

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  product     Product      @relation(fields: [productId], references: [id])
  digitalCode DigitalCode? @relation(fields: [digitalCodeId], references: [id])

  @@unique([digitalCodeId])
  @@index([orderId])
}

model EmailLog {
  id                String   @id @default(cuid())
  orderId           String?
  customerId        String?
  // type: "order_received" | "payment_submitted" | "payment_confirmed"
  //      | "payment_rejected" | "payment_issue" | "code_delivered"
  type              String
  templateKey       String?
  recipient         String
  subject           String
  body              String
  html              String   @default("")
  text              String   @default("")
  provider          String   @default("simulation")
  providerMessageId String?
  status            String   @default("simulated")
  errorMessage      String?
  manuallyEdited    Boolean  @default(false)
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  order    Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([templateKey])
}

// Customer-uploaded payment proof (PNG / JPG / JPEG / PDF).
// Stored as base64 in PostgreSQL until object storage is configured.
// Guided-support request submitted from /support. Standalone (no hard FK to
// Order — the customer may reference any order string or none). Attachments
// are stored inline as base64 like PaymentProof until object storage exists.
model SupportTicket {
  id               String    @id @default(cuid())
  // Public reference shown to the customer, e.g. "GH-S-482913".
  reference        String    @unique
  // Category key: paiement | livraison | code | commande | remboursement | compte | technique | autre
  category         String
  // Sub-issue id (p1, l2, …) + its French label frozen at submit time.
  subIssue         String
  subIssueLabel    String
  // Optional order reference chosen/typed by the customer (e.g. "#000128").
  orderRef         String?
  name             String
  email            String
  phone            String?
  message          String?
  // [{ fileName, mimeType, dataBase64 }] — capped by the server action.
  attachments      Json?
  // Logged-in customer when available (soft link, ticket survives deletion).
  customerId       String?
  // status: "open" | "answered" | "closed"
  status           String    @default("open")
  // Optional close outcome chosen by the admin: "resolved" | "cancelled" | "dismissed".
  resolution       String?
  // Admin replies sent to the customer: [{ body, createdAt }] — the customer
  // sees these on the account/tracking pages; each also triggers a reply email.
  replies          Json?
  // Discord #support card/thread tracking — one card per ticket (edited in
  // place as status changes) with a thread holding the full conversation.
  discordMessageId String?
  discordThreadId  String?
  // Post-close feedback: a random token gates the public feedback page, then
  // the customer's rating (1-5) and comment are stored back here.
  feedbackToken    String?   @unique
  feedbackRating   Int?
  feedbackComment  String?
  feedbackAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([customerId])
}

model PaymentProof {
  id         String   @id @default(cuid())
  orderId    String   @unique
  fileName   String
  mimeType   String
  data       String // base64-encoded file content
  uploadedAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([uploadedAt])
}

// Audit trail for payment lifecycle events.
model PaymentEvent {
  id         String   @id @default(cuid())
  orderId    String
  type       String // "status_change" | "proof_uploaded" | "admin_note"
  fromStatus String?
  toStatus   String?
  note       String?
  createdAt  DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

// Dedupe/idempotency ledger for verified payment-provider webhooks (PayPal,
// etc). Only stores identifiers needed to reconcile — never the raw payload,
// which may carry payer/payment details.
model PaymentWebhookEvent {
  id          String   @id @default(cuid())
  provider    String // "paypal"
  eventId     String   @unique
  eventType   String
  resourceId  String?
  orderId     String?
  processedAt DateTime @default(now())

  @@index([provider])
  @@index([orderId])
}

// Generic, reorderable payment method shown at checkout. One row per
// customer-facing method (a bank account, a crypto wallet, PayPal, card,
// cash, or a fully custom method) — replaces the old fixed
// Bank/CryptoWallet/PaymentMethodConfig tables so admins can add/remove/
// reorder/archive any number of methods of any type.
model PaymentMethod {
  id            String    @id @default(cuid())
  type          String // "bank" | "paypal" | "crypto" | "card" | "cash" | "custom"
  name          String // customer-facing name
  subtitle      String    @default("")
  customerNote  String    @default("")
  status        String    @default("active") // "active" | "inactive"
  visible       Boolean   @default(true)
  sortOrder     Int       @default(0)
  logoUrl       String?
  initials      String    @default("")
  accentColor   String    @default("#3e7bfa")
  logoType      String    @default("initials") // "initials" | "image" | "icon"
  details       Json      @default("{}") // per-type fields (rib, walletAddress, paypalEmail, ...)
  proofRequired Boolean   @default(true)
  internalNote  String    @default("")
  minAmount     Float?
  maxAmount     Float?
  regions       String[]  @default([])
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([sortOrder])
}

// Global support contact info.
model SupportConfig {
  id             String   @id @default(cuid())
  whatsappNumber String   @default("+212 600 000 000")
  supportEmail   String   @default("support@ghost.ma")
  instructions   String   @default("")
  updatedAt      DateTime @default(now()) @updatedAt
}

model StoreSetting {
  id        String   @id
  value     Json
  updatedAt DateTime @default(now()) @updatedAt
}

// ── Pricing subsystem (Phase 1) ──────────────────────────────────────────────
// Provider COST layer. Deliberately decoupled from ProductVariant.priceMad so a
// Reloadly sync can never touch a live customer price. One row per
// (environment, Reloadly product, recipient face value). Money stored as
// Decimal — never Float — so the cost is exactly reproducible. `environment`
// keeps sandbox and live cost data distinguishable and un-mixable.
model ReloadlyProviderCost {
  id                            String   @id @default(cuid())
  environment                   String // "sandbox" | "live"
  reloadlyProductId             Int
  productName                   String?
  denominationType              String // "FIXED" | "RANGE"
  recipientFaceValue            Decimal  @db.Decimal(18, 4)
  recipientCurrency             String
  senderCurrency                String
  // Inputs, stored so the computed cost is fully explainable/recalculable:
  senderBaseCost                Decimal  @db.Decimal(18, 6)
  discountPercentage            Decimal  @db.Decimal(9, 4)
  senderFee                     Decimal  @db.Decimal(18, 6)
  senderFeePercentage           Decimal  @db.Decimal(9, 4)
  recipientToSenderExchangeRate Decimal? @db.Decimal(18, 8)
  // Output of the provider-cost formula (sender/wallet currency):
  computedProviderCost          Decimal  @db.Decimal(18, 6)
  syncedAt                      DateTime @default(now())
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @default(now()) @updatedAt

  @@unique([environment, reloadlyProductId, recipientFaceValue])
  @@index([environment, reloadlyProductId])
}

// Audit of each Reloadly cost-sync run so the admin "sync failed" state is
// visible and a failed sync can never be mistaken for fresh data.
model PricingSyncRun {
  id             String    @id @default(cuid())
  environment    String // "sandbox" | "live"
  status         String // "success" | "partial" | "failed"
  productsSynced Int       @default(0)
  costsUpserted  Int       @default(0)
  error          String?
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?

  @@index([environment, startedAt])
}

// ── Expense ledger (admin-only) ──────────────────────────────────────────────
// Ghost.ma's own operating costs. The recurring subscription DEFINITION
// (RecurringExpense) is kept separate from the immutable paid OCCURRENCES
// (ExpenseEntry) so historical payments are never overwritten. Money is Decimal
// (never Float); the DH reporting figure snapshots the FX rate used at record
// time so past totals never shift when rates are edited later. Never exposed to
// customers — admin-only, behind assertAdminAccess.
model RecurringExpense {
  id                 String    @id @default(cuid())
  name               String
  description        String    @default("")
  category           String
  currency           String    @default("MAD")
  // Null for a pure usage-based subscription whose amount is only known per
  // invoice — each occurrence confirms its own figure.
  amount             Decimal?  @db.Decimal(18, 6)
  isUsageBased       Boolean   @default(false)
  // frequency: "weekly" | "monthly" | "quarterly" | "semiannual" | "yearly" | "custom"
  frequency          String
  customIntervalDays Int?
  // Exact next billing date is stored, never inferred only from the frequency.
  nextBillingDate    DateTime
  startDate          DateTime?
  endDate            DateTime?
  autoRenew          Boolean   @default(true)
  paymentAccount     String?
  notes              String?
  // Days-before offsets to remind on, e.g. [7, 3, 1].
  reminderDaysBefore Int[]     @default([])
  remindOnDue        Boolean   @default(true)
  remindOverdue      Boolean   @default(true)
  // status: "active" | "paused" | "cancelled"  (cancelled = terminated/inactive)
  status             String    @default("active")
  // Set when the subscription is dropped/expired. terminationType:
  // "cancelled" (résilié) | "expired" | "dropped". Cleared on reactivation.
  terminationType    String?
  terminatedAt       DateTime?
  terminationReason  String?
  createdBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  occurrences   ExpenseEntry[]
  notifications ExpenseNotificationLog[]

  @@index([status, nextBillingDate])
  @@index([category])
}

model ExpenseEntry {
  id                 String    @id @default(cuid())
  // Null for a standalone one-time / usage / credit entry.
  recurringExpenseId String?
  name               String
  category           String
  // type: "recurring" | "one_time" | "usage_based" | "credit"
  type               String
  // amountOriginal is null while an estimate/usage amount is still pending.
  amountOriginal     Decimal?  @db.Decimal(18, 6)
  currency           String    @default("MAD")
  amountEstimated    Boolean   @default(false)
  // Rate + converted DH amount are frozen at record time so editing global FX
  // rates later never changes historical totals.
  exchangeRateToMad  Decimal?  @db.Decimal(18, 8)
  amountMad          Decimal?  @db.Decimal(18, 6)
  // status: "upcoming" | "pending" | "paid" | "overdue" | "cancelled" | "estimated" | "credit"
  status             String    @default("upcoming")
  dueDate            DateTime?
  occurrenceDate     DateTime?
  paidDate           DateTime?
  paidAmount         Decimal?  @db.Decimal(18, 6)
  paidCurrency       String?
  paidExchangeRate   Decimal?  @db.Decimal(18, 8)
  paymentReference   String?
  paymentAccount     String?
  invoiceReference   String?
  // Optional receipt stored as base64 in Postgres (like PaymentProof) until
  // object storage exists. Served only through an admin-only action.
  receiptFileName    String?
  receiptMimeType    String?
  receiptData        String?
  notes              String?
  createdBy          String?
  updatedBy          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @default(now()) @updatedAt

  recurringExpense RecurringExpense?        @relation(fields: [recurringExpenseId], references: [id], onDelete: SetNull)
  adjustments      ExpenseAdjustment[]
  notifications    ExpenseNotificationLog[]

  @@index([status])
  @@index([category])
  @@index([dueDate])
  @@index([recurringExpenseId])
  @@index([createdAt])
}

// Append-only audit for meaningful edits to a paid ExpenseEntry: the previous
// value is preserved rather than silently rewritten. Mirrors PaymentEvent.
model ExpenseAdjustment {
  id             String   @id @default(cuid())
  expenseEntryId String
  // kind: "edit" | "correction" | "reversal"
  kind           String   @default("edit")
  field          String
  oldValue       Json?
  newValue       Json?
  reason         String?
  createdBy      String?
  createdAt      DateTime @default(now())

  expenseEntry ExpenseEntry @relation(fields: [expenseEntryId], references: [id], onDelete: Cascade)

  @@index([expenseEntryId])
}

// Discord notification history + idempotency ledger for the expense channel.
// `dedupeKey` is unique so a double-firing cron (reminders/summary) can never
// post the same message twice.
model ExpenseNotificationLog {
  id                 String    @id @default(cuid())
  recurringExpenseId String?
  expenseEntryId     String?
  occurrenceDate     DateTime?
  // kind: created | paid | cancelled | edited | reminder_7d | reminder_3d
  //     | reminder_1d | due | overdue | usage_confirmed | monthly_summary
  kind               String
  channel            String    @default("expenses")
  discordMessageId   String?
  // status: "sent" | "failed"
  status             String
  error              String?
  dedupeKey          String    @unique
  createdAt          DateTime  @default(now())

  recurringExpense RecurringExpense? @relation(fields: [recurringExpenseId], references: [id], onDelete: Cascade)
  expenseEntry     ExpenseEntry?     @relation(fields: [expenseEntryId], references: [id], onDelete: Cascade)

  @@index([recurringExpenseId])
  @@index([expenseEntryId])
  @@index([kind, createdAt])
}

// End-of-month expense review: one row per ending month (monthKey "YYYY-MM" in
// the business timezone). The unique monthKey is the idempotency anchor so a
// re-run of the evening cron never posts a second report, while a row still in
// "pending"/"failed" can be safely retried. Acknowledgement ("Tout est correct")
// is recorded here from the admin panel — it never mutates any expense record.
model ExpenseMonthlyReview {
  id               String    @id @default(cuid())
  // "YYYY-MM" of the month being reviewed, computed in the business timezone.
  monthKey         String    @unique
  // status: "pending" | "sending" | "sent" | "failed"
  status           String    @default("pending")
  attemptCount     Int       @default(0)
  discordMessageId String?
  error            String?
  sentAt           DateTime?
  // Set when an admin marks the review acknowledged. Preserved as evidence.
  acknowledgedAt   DateTime?
  acknowledgedBy   String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt

  @@index([monthKey])
}

// §10 fulfillment cost reconciliation: after a real Reloadly order, compare the
// estimated provider cost (from synced catalog data) with the actual
// balanceInfo.cost Reloadly charged. Append-only; never feeds back into any
// customer price. Never exposed to customers.
model ReloadlyCostReconciliation {
  id                    String   @id @default(cuid())
  orderId               String
  deliveredCodeId       String?
  reloadlyTransactionId Int?
  environment           String
  reloadlyProductId     Int
  recipientFaceValue    Decimal? @db.Decimal(18, 4)
  estimatedProviderCost Decimal? @db.Decimal(18, 6)
  actualProviderCost    Decimal  @db.Decimal(18, 6)
  currency              String
  differenceAmount      Decimal? @db.Decimal(18, 6)
  createdAt             DateTime @default(now())

  @@index([orderId])
  @@index([environment, createdAt])
}

// ── Promo codes & Ghost Credit ───────────────────────────────────────────────
// A customer-facing promotional code. Exactly ONE reward type per code (see
// rewardType). Immediate-discount codes reduce what the customer pays now;
// Ghost Credit codes never touch the paid total and instead grant wallet credit
// AFTER the order reaches its successful paid state. Money is whole MAD (Int),
// matching Order.totalMad. Percentages use Decimal so 8.5% is exact. Editing or
// disabling a code never rewrites historical orders — each order keeps its own
// OrderPromotionSnapshot. See docs/promo-codes.md for the redemption lifecycle.
model PromoCode {
  id           String  @id @default(cuid())
  // Normalized to trimmed UPPERCASE, unique, matched case-insensitively at
  // checkout (the stored value is already uppercase, the lookup uppercases too).
  code         String  @unique
  internalName String
  description  String  @default("")
  active       Boolean @default(true)

  // rewardType: "PERCENT_DISCOUNT" | "FIXED_DISCOUNT" | "FIXED_GHOST_CREDIT"
  //           | "PERCENT_GHOST_CREDIT" (see src/lib/types.ts PromoRewardType).
  rewardType String

  // Reward configuration — only the subset relevant to rewardType is populated:
  //  PERCENT_DISCOUNT      → percentValue (+ optional maxDiscountMad)
  //  FIXED_DISCOUNT        → fixedAmountMad
  //  FIXED_GHOST_CREDIT    → fixedAmountMad (+ optional credit expiry)
  //  PERCENT_GHOST_CREDIT  → percentValue (+ optional maxCreditMad, + expiry)
  percentValue        Decimal?  @db.Decimal(6, 3)
  fixedAmountMad      Int?
  maxDiscountMad      Int?
  maxCreditMad        Int?
  // Optional Ghost Credit expiration: a rolling period in days from grant, or a
  // fixed calendar date. If both are null the credit never expires.
  creditExpiresInDays Int?
  creditExpiresAt     DateTime?

  // Validity window (business timezone). Null start = valid immediately; null
  // end = no expiration.
  startAt DateTime?
  endAt   DateTime?

  // Usage limits (all optional, all enforced server-side).
  maxTotalUses       Int?
  maxUsesPerCustomer Int?
  firstOrderOnly     Boolean @default(false)
  loggedInOnly       Boolean @default(false)
  minSubtotalMad     Int?
  maxSubtotalMad     Int?

  // Applicability: when there are NO product and NO category links the code
  // applies to all eligible products. When both kinds of links exist a cart item
  // is eligible if it matches EITHER a selected product OR a selected category
  // (OR semantics — see docs/promo-codes.md and the admin UI note).

  // Denormalized live counter of reserved+finalized redemptions, kept in sync
  // transactionally so the "final available use" race is decided by a single
  // conditional UPDATE. The authoritative history is PromoRedemption rows.
  reservedUses Int @default(0)

  archivedAt DateTime?
  createdBy  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt

  products    PromoCodeProduct[]
  categories  PromoCodeCategory[]
  redemptions PromoRedemption[]
  snapshots   OrderPromotionSnapshot[]
  creditTxns  GhostCreditTransaction[]
  events      PromoCodeEvent[]

  @@index([active])
  @@index([archivedAt])
  @@index([rewardType])
}

// Parent-product applicability link. Real DB relation (never pasted URLs/titles).
model PromoCodeProduct {
  id          String   @id @default(cuid())
  promoCodeId String
  productId   String
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, productId])
  @@index([promoCodeId])
  @@index([productId])
}

// Category applicability link. Real DB relation.
model PromoCodeCategory {
  id          String   @id @default(cuid())
  promoCodeId String
  categoryId  String
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, categoryId])
  @@index([promoCodeId])
  @@index([categoryId])
}

// One redemption per order (the @@unique on orderId also prevents applying two
// codes / the same code twice to one order). Lifecycle:
//   reserved  — attached at order creation, counts toward usage limits
//   finalized — order reached its successful paid state
//   released  — order cancelled/rejected/expired; frees the reservation
model PromoRedemption {
  id            String    @id @default(cuid())
  promoCodeId   String
  orderId       String    @unique
  customerId    String?
  // Snapshot of the checkout identity used for per-customer limits, so the count
  // is stable even if the guest never creates an account.
  customerEmail String
  // status: "reserved" | "finalized" | "released"
  status        String    @default("reserved")
  finalizedAt   DateTime?
  releasedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer  Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([promoCodeId, status])
  @@index([promoCodeId, customerEmail])
  @@index([customerId])
}

// Immutable promotion snapshot captured at order creation. Historical orders are
// NEVER recomputed from later promo-code edits — everything needed to explain
// and refund the order lives here.
model OrderPromotionSnapshot {
  id                  String    @id @default(cuid())
  orderId             String    @unique
  // Kept as SetNull so deleting a code never destroys order history; the exact
  // code text is snapshotted regardless.
  promoCodeId         String?
  code                String
  rewardType          String
  configuredPercent   Decimal?  @db.Decimal(6, 3)
  configuredFixedMad  Int?
  maxDiscountMad      Int?
  maxCreditMad        Int?
  eligibleSubtotalMad Int
  discountMad         Int       @default(0)
  expectedCreditMad   Int       @default(0)
  creditExpiresAt     DateTime?
  // OrderItem ids that were eligible for this promo.
  eligibleLineItemIds String[]  @default([])
  // Deterministic per-line discount allocation: [{ orderItemId, discountMad }].
  // Sums exactly to discountMad; used for refund accounting.
  lineAllocations     Json?
  // Validation inputs frozen at apply time (isLoggedIn, isFirstOrder, subtotal…).
  validationContext   Json?
  createdAt           DateTime  @default(now())

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  promoCode PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  @@index([promoCodeId])
}

// Append-only Ghost Credit ledger. The wallet balance is DERIVED from these
// rows (and cached on Customer.ghostCreditBalanceMad transactionally). A credit
// adds to the balance; a debit subtracts. A reversal is a debit that offsets an
// earlier credit — historical rows are never edited or deleted.
model GhostCreditTransaction {
  id               String  @id @default(cuid())
  customerId       String
  // Positive magnitude in whole MAD; the sign is carried by `direction`.
  amountMad        Int
  // direction: "credit" | "debit"
  direction        String
  // reason: "promo_reward" | "promo_reversal" | "spending_milestone_reward"
  //       | "milestone_reversal" | "order_spend" | "order_spend_refund"
  //       | "admin_grant" | "admin_reversal" | "expiration"
  reason           String
  // Whether this entry is a QUALIFYING earning event that resets the 180-day
  // inactivity timer. TRUE only for promo Ghost Credit rewards and spending-
  // milestone rewards granted after a paid+completed order. NEVER inferred from
  // the direction/amount — it is set explicitly by the granting code and stored
  // here so reconciliation can verify the wallet deadline against it.
  resetsExpiration Boolean @default(false)

  promoCodeId          String?
  orderId              String?
  rewardType           String?
  eligibleSubtotalMad  Int?
  configuredPercent    Decimal? @db.Decimal(6, 3)
  configuredFixedMad   Int?
  // Spending-milestone context (set on milestone reward + reversal rows).
  milestoneId          String?
  thresholdMad         Int?
  qualifyingSpendMad   Int?
  // For reversal rows: the original ledger entry being reversed (audit link).
  relatedTransactionId String?
  // Free-form audit context (never rendered as customer data).
  metadata             Json?

  // status: "active" | "reversed" | "expired"
  status         String    @default("active")
  // Guarantees exactly-once grants/reversals across duplicate webhooks, retried
  // admin actions, and double completion runs. E.g. "promo-credit:{orderId}:{promoCodeId}".
  idempotencyKey String    @unique
  expiresAt      DateTime?
  // "system" for automated grants, or the admin's name for manual corrections.
  source         String    @default("system")
  note           String?
  createdAt      DateTime  @default(now())

  customer  Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  promoCode PromoCode?         @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  order     Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  milestone SpendingMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  @@index([customerId, status])
  @@index([orderId])
  @@index([promoCodeId])
  @@index([milestoneId])
}

// Configurable, cumulative account-level spending milestone: "spend X total →
// earn Y Ghost Credit", granted once per customer per milestone after a
// paid+completed order crosses the threshold. NOT points, NOT automatic
// per-order cashback. Editing a live threshold/reward should ARCHIVE this row
// and create a new one (new id) so historical grants stay linked to the exact
// milestone version that produced them (see SpendingMilestoneGrant).
model SpendingMilestone {
  id                String    @id @default(cuid())
  internalName      String
  publicTitle       String
  publicDescription String    @default("")
  // Required cumulative qualifying spend to unlock, and the reward, in whole MAD.
  thresholdMad      Int
  rewardMad         Int
  active            Boolean   @default(true)
  startsAt          DateTime?
  endsAt            DateTime?
  displayOrder      Int       @default(0)
  // Monotonic version bumped when superseded by an edited copy (audit clarity).
  version           Int       @default(1)
  archivedAt        DateTime?
  createdBy         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  grants     SpendingMilestoneGrant[]
  creditTxns GhostCreditTransaction[]

  @@index([active, displayOrder])
  @@index([archivedAt])
  @@index([thresholdMad])
}

// One row per (milestone, customer) grant — the @@unique makes a milestone
// impossible to award twice, independent of application logic. `status` flips to
// "reversed" (never deleted) when a refund drops qualifying spend below the
// threshold. The reward itself lives in the GhostCreditTransaction ledger; this
// is the reporting + idempotency anchor.
model SpendingMilestoneGrant {
  id                 String    @id @default(cuid())
  milestoneId        String
  customerId         String
  // The order whose completion crossed the threshold.
  orderId            String?
  thresholdMad       Int
  rewardMad          Int
  // Qualifying lifetime spend at grant time (audit).
  qualifyingSpendMad Int
  // status: "granted" | "reversed"
  status             String    @default("granted")
  reversedAt         DateTime?
  createdAt          DateTime  @default(now())

  milestone SpendingMilestone @relation(fields: [milestoneId], references: [id])
  customer  Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order     Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([milestoneId, customerId])
  @@index([customerId, status])
  @@index([milestoneId])
  @@index([orderId])
}

// Append-only admin/audit timeline for a promo code (mirrors PaymentEvent).
model PromoCodeEvent {
  id          String   @id @default(cuid())
  promoCodeId String
  // type: "created" | "updated" | "activated" | "deactivated" | "archived"
  //     | "unarchived" | "duplicated" | "deleted" | "manual_credit" | "note"
  type        String
  note        String?
  createdBy   String?
  createdAt   DateTime @default(now())

  promoCode PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@index([promoCodeId])
}
