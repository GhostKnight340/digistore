# ─── Ghost.ma environment files ──────────────────────────────────────────────
# Template only — NEVER put real secrets here (this file IS committed).
# Copy the block below into the correct file. See docs/db-safety.md.
#
#   .env.local             → your LOCAL / DEV Neon branch.
#                            Loaded automatically by `npm run dev` and by the
#                            tsx scripts (via scripts/lib/load-env.mjs).
#   .env.production.local  → PRODUCTION credentials.
#                            NEVER loaded by dev or normal scripts. Loaded ONLY
#                            by `npm run prod:status` / `npm run prod:migrate`.
#   .env                   → optional dev fallback. The Prisma CLI (`prisma
#                            migrate dev`, `prisma studio`) auto-loads ONLY this
#                            file, so if you use those directly keep dev creds here.
#
# Both .env.local and .env.production.local are gitignored.

# ── Database (required) ───────────────────────────────────────────────────────
# Pooled connection for the running app:
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Direct, NON-pooled connection for migrations (drop the "-pooler" from the host):
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# ── Production marker (put this in .env.production.local ONLY) ─────────────────
# Makes the safety guard treat this connection as production and refuse writes
# unless you pass CONFIRM_PRODUCTION_DB=true. The guard ALSO auto-detects prod by
# comparing the active host to .env.production.local, so this is belt-and-braces.
# GHOST_DB_ENV=production

# ── Auth / app (required in production) ───────────────────────────────────────
# Generate a fresh value with: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_GENERATED_SECRET"
# NEXT_PUBLIC_SITE_URL="https://ghost.ma"

# ── Optional integrations (see docs/production-env.md for the full list) ──────
# RESEND_API_KEY=
# PAYPAL_CLIENT_ID=            PAYPAL_CLIENT_SECRET=      PAYPAL_WEBHOOK_ID=
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=                          PAYPAL_ENV=sandbox
# DISCORD_INTEGRATION_ENABLED=true  DISCORD_BOT_TOKEN=   DISCORD_GUILD_ID=
# DISCORD_CLIENT_ID=          DISCORD_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=           GOOGLE_CLIENT_SECRET=
# RELOADLY_CLIENT_ID=         RELOADLY_CLIENT_SECRET=    RELOADLY_ENV=sandbox
