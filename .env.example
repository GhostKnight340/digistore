# ─── Ghost.ma environment files ──────────────────────────────────────────────
# Template only — NEVER put real secrets here (this file IS committed).
# Copy the block below into the correct file. See docs/db-safety.md.
#
#   .env.local             → your LOCAL / DEV Neon branch.
#                            Loaded automatically by `npm run dev` and by the
#                            tsx scripts (via scripts/lib/load-env.mjs).
#   .env.production.local  → PRODUCTION credentials.
#                            NEVER loaded by dev or normal scripts. Loaded ONLY
#                            by `npm run prod:status` / `npm run prod:migrate`.
#   .env                   → optional dev fallback. The Prisma CLI (`prisma
#                            migrate dev`, `prisma studio`) auto-loads ONLY this
#                            file, so if you use those directly keep dev creds here.
#
# Both .env.local and .env.production.local are gitignored.

# ── Database (required) ───────────────────────────────────────────────────────
# Pooled connection for the running app:
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Direct, NON-pooled connection for migrations (drop the "-pooler" from the host):
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# ── Production marker (put this in .env.production.local ONLY) ─────────────────
# Makes the safety guard treat this connection as production and refuse writes
# unless you pass CONFIRM_PRODUCTION_DB=true. The guard ALSO auto-detects prod by
# comparing the active host to .env.production.local, so this is belt-and-braces.
# GHOST_DB_ENV=production

# ── Auth / app (required in production) ───────────────────────────────────────
# Generate a fresh value with: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_GENERATED_SECRET"
# NEXT_PUBLIC_SITE_URL="https://ghost.ma"

# ── Optional integrations (see docs/production-env.md for the full list) ──────
# RESEND_API_KEY=
# PAYPAL_CLIENT_ID=            PAYPAL_CLIENT_SECRET=      PAYPAL_WEBHOOK_ID=
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=                          PAYPAL_ENV=sandbox
# DISCORD_INTEGRATION_ENABLED=true  DISCORD_BOT_TOKEN=   DISCORD_GUILD_ID=
# DISCORD_CLIENT_ID=          DISCORD_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=           GOOGLE_CLIENT_SECRET=
# RELOADLY_CLIENT_ID=         RELOADLY_CLIENT_SECRET=    RELOADLY_ENV=sandbox

# ═══════════════════════════════════════════════════════════════════════════════
# Every remaining variable the code actually reads. All values below are
# placeholders — never commit a real one.
#
# Each entry is tagged twice:
#   scope   required-all | production-only | staging-only | optional
#   secrecy SECRET (never leaves the server) | PUBLIC (safe in the browser)
#
# RULE: only NEXT_PUBLIC_* variables reach the browser, and every one of them
# must be PUBLIC. The full NEXT_PUBLIC_ set is: SITE_URL, APP_URL, SUPPORT_EMAIL,
# GA_ID, PAYPAL_CLIENT_ID, DISCORD_APPLICATION_ID, SENTRY_DSN, plus the
# VERCEL_ENV / VERCEL_GIT_COMMIT_SHA mirrors Vercel injects itself — URLs, a
# support address, and vendor-issued public identifiers. No secret is, or
# may become, a NEXT_PUBLIC_ variable. The matching secrets are deliberately
# NOT prefixed: PAYPAL_CLIENT_SECRET, GA_API_SECRET, SENTRY_AUTH_TOKEN.
# ═══════════════════════════════════════════════════════════════════════════════

# ── FazerCards supplier (optional; SECRET) ────────────────────────────────────
# FazerCards has NO sandbox — every issued key is live and every order spends
# real USD from the shared prepaid wallet. There is therefore no "test
# credentials" setup that makes staging safe; safety comes from FAZERCARDS_MODE
# below, which only reaches "live" on a production runtime with an explicit
# opt-in. Prefer to leave the key UNSET on staging regardless.
# Never expose any of these via NEXT_PUBLIC_*.
#
# Reseller API key (reseller hub → Profile).
# FAZERCARDS_API_KEY=
# Kill switch. Set to "false" to hard-disable the supplier even if a key is
# present — survives a leaked or forgotten credential.
# FAZERCARDS_ENABLED="true"
# "live" | "dry_run". Anything other than "live" (including unset) simulates
# order placement instead of dispatching it. "live" additionally requires a
# production runtime, so a value copied into staging cannot spend money.
# FAZERCARDS_MODE="dry_run"
# HMAC secret for inbound order webhooks (hub → Settings → Webhook, or
# GET /account/webhook). Without it, completion relies on reconciliation polling.
# FAZERCARDS_WEBHOOK_SECRET=
# API base override. Defaults to https://api.fzr.cards/api/v2. Must be HTTPS.
# FAZERCARDS_BASE_URL="https://api.example-supplier.test"

# ── Scheduled jobs (production-only; SECRET) ──────────────────────────────────
# Shared bearer token Vercel Cron presents to the /api/cron/* routes.
# Generate with: openssl rand -hex 32
# CRON_SECRET=

# ── Session signing (required-all; SECRET) ────────────────────────────────────
# AUTH_SECRET above is the primary name. These two are accepted as fallbacks by
# the auth layer; set ONE of the three, not all. openssl rand -base64 32
# SESSION_SECRET=
# NEXTAUTH_SECRET=

# ── Admin identity (production-only; SECRET-ish — real inboxes) ───────────────
# Address that receives operational alerts / owns the first admin account.
# ADMIN_EMAIL="admin@example.com"
# GHOST_ADMIN_EMAIL="owner@example.com"

# ── Outbound e-mail (production-only; ADDRESSES are PUBLIC, behaviour flags) ──
# EMAIL_FROM_ADDRESS="no-reply@example.com"
# EMAIL_FROM_NAME="Ghost"
# Opt-in to REAL sending. Anything other than "true" simulates delivery.
# NEVER set this to true on staging without EMAIL_TEST_ALLOWLIST.
# ENABLE_REAL_EMAILS=false
# Comma-separated addresses that may receive real mail on non-production
# environments. Required whenever ENABLE_REAL_EMAILS=true off production.
# EMAIL_TEST_ALLOWLIST="you@example.com,teammate@example.com"
# Public support address shown in the UI and in e-mail footers.
# SUPPORT_EMAIL="support@example.com"
# NEXT_PUBLIC_SUPPORT_EMAIL="support@example.com"      # optional; PUBLIC

# ── Canonical URLs (required in production; all PUBLIC) ───────────────────────
# Used for absolute links in e-mails, sitemaps, OG tags and redirects.
# Set these per environment: staging must point at the staging host.
# NEXT_PUBLIC_APP_URL="https://ghost.ma"
# APP_URL="https://ghost.ma"
# SITE_URL="https://ghost.ma"

# ── Discord (optional; IDs are PUBLIC, tokens/secrets are SECRET) ─────────────
# DISCORD_APPLICATION_ID=""                     # optional; PUBLIC
# NEXT_PUBLIC_DISCORD_APPLICATION_ID=""         # optional; PUBLIC
# Discord user id that receives owner-only DMs. Optional; PUBLIC (an id).
# DISCORD_OWNER_USER_ID=""
# Shared secret between the app and the standalone DM worker process.
# Optional; SECRET. openssl rand -hex 32
# DISCORD_DM_WORKER_SECRET=

# ── Analytics — Google Analytics 4 (production-only) ──────────────────────────
# Measurement id. PUBLIC by design (it ships in the page). With this UNSET,
# analytics is fully disabled — there is no fallback id.
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# Measurement Protocol API secret, for the SERVER-SIDE `purchase` event only.
# SECRET — never prefix this with NEXT_PUBLIC_. Create it in GA4 under
# Admin → Data Streams → your stream → Measurement Protocol API secrets.
# Unset = the server-side purchase event is a silent no-op. See
# docs/analytics-events.md.
# GA_API_SECRET=

# ── Error monitoring — Sentry (optional; unset = fully disabled) ──────────────
# The DSN is a write-only ingest URL and is PUBLIC by design (it ships in the
# browser bundle). Set NEXT_PUBLIC_SENTRY_DSN for browser errors and SENTRY_DSN
# for server/edge errors; they are normally the same value.
# SENTRY_DSN="https://PUBLIC_KEY@oXXXX.ingest.sentry.io/PROJECT_ID"
# NEXT_PUBLIC_SENTRY_DSN="https://PUBLIC_KEY@oXXXX.ingest.sentry.io/PROJECT_ID"
# BUILD-TIME ONLY, SECRET: authorises source-map upload during `next build`.
# Set it in the Vercel build environment, never at runtime, never NEXT_PUBLIC_.
# Unset = source maps are simply not uploaded; the build still succeeds.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=""                                 # optional; PUBLIC (slug)
# SENTRY_PROJECT=""                             # optional; PUBLIC (slug)
